<%- include('partials/header', { title: 'Trang chủ' }) %>
<%- include('partials/navbar') %>

<% if (error) { %>
  <div class="max-w-[1280px] mx-auto px-4 md:px-10 mt-4">
    <div class="bg-error-container text-error px-4 py-3 rounded-lg text-body-md"><%= error %></div>
  </div>
<% } %>
<% if (success) { %>
  <div class="max-w-[1280px] mx-auto px-4 md:px-10 mt-4">
    <div class="bg-secondary-container text-on-secondary-container px-4 py-3 rounded-lg text-body-md"><%= success %></div>
  </div>
<% } %>

<!-- Hero Section -->
<section class="hero-bg max-w-[1280px] mx-auto px-4 md:px-10 pt-14 pb-20 relative">
  <!-- Floating orbs -->
  <div class="hero-orb w-72 h-72 bg-primary/10 absolute -top-10 -right-20 opacity-60" style="animation-delay:0s;"></div>
  <div class="hero-orb w-48 h-48 bg-secondary/10 absolute bottom-0 -left-10 opacity-50" style="animation-delay:3s;"></div>

  <div class="glass-panel p-8 md:p-16 text-center animate-on-scroll relative overflow-hidden">
    <!-- Inner glow -->
    <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-secondary/5 rounded-2xl pointer-events-none"></div>

    <div class="relative">
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-primary/10 text-primary text-[12px] font-semibold mb-5 border border-primary/20">
        <span class="status-dot status-dot-green" style="animation: pulse 2s infinite;"></span>
        Nền tảng gia sư #1 Bách Khoa
      </span>
      <h1 class="text-[clamp(2.2rem,5vw,3.5rem)] font-bold text-on-surface leading-tight mb-5">
        Tìm <span class="text-gradient">Gia Sư</span> Phù Hợp Nhất
      </h1>
      <p class="text-[clamp(1rem,2vw,1.125rem)] text-on-surface-variant max-w-xl mx-auto mb-8 leading-relaxed animate-on-scroll delay-100">
        Kết nối học viên với gia sư chất lượng. Đăng yêu cầu, nhận ứng tuyển từ nhiều gia sư, và chọn người phù hợp nhất.
      </p>
      <div class="flex flex-wrap justify-center gap-3 animate-on-scroll delay-200">
        <% if (!user) { %>
          <button onclick="openAuthModal('register')" class="btn-primary text-[15px] px-8 py-3">Bắt đầu ngay</button>
        <% } else if (role === 'hoc_vien') { %>
          <a href="/dang-tin" class="btn-primary no-underline text-[15px] px-8 py-3">Đăng yêu cầu tìm gia sư</a>
        <% } else { %>
          <a href="/yeu-cau" class="btn-primary no-underline text-[15px] px-8 py-3">Xem yêu cầu đang mở</a>
        <% } %>
        <a href="/yeu-cau" class="btn-outline no-underline text-[15px] px-8 py-3">Khám phá →</a>
      </div>
    </div>
  </div>
</section>

<!-- Stats -->
<section class="max-w-[1280px] mx-auto px-4 md:px-10 pb-14">
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <div class="card text-center animate-on-scroll group">
      <div class="text-[2.5rem] font-bold text-primary mb-1 stat-number group-hover:scale-110 transition-transform">100+</div>
      <div class="text-[13px] text-on-surface-variant font-medium">Gia sư chất lượng</div>
    </div>
    <div class="card text-center animate-on-scroll delay-100 group">
      <div class="text-[2.5rem] font-bold text-secondary mb-1 stat-number group-hover:scale-110 transition-transform">500+</div>
      <div class="text-[13px] text-on-surface-variant font-medium">Lớp học thành công</div>
    </div>
    <div class="card text-center animate-on-scroll delay-200 group">
      <div class="text-[2.5rem] font-bold text-primary mb-1 stat-number group-hover:scale-110 transition-transform">4.8★</div>
      <div class="text-[13px] text-on-surface-variant font-medium">Điểm đánh giá TB</div>
    </div>
    <div class="card text-center animate-on-scroll delay-300 group">
      <div class="text-[2.5rem] font-bold text-secondary mb-1 stat-number group-hover:scale-110 transition-transform">24/7</div>
      <div class="text-[13px] text-on-surface-variant font-medium">Hỗ trợ liên tục</div>
    </div>
  </div>
</section>

<!-- Yêu cầu đang mở -->
<section class="max-w-[1280px] mx-auto px-4 md:px-10 pb-14">
  <div class="flex items-center justify-between mb-7 animate-on-scroll">
    <div>
      <h2 class="text-[1.6rem] font-bold text-on-surface">Yêu cầu đang mở</h2>
      <p class="text-[13px] text-on-surface-variant mt-0.5">Các lớp học đang tìm gia sư</p>
    </div>
    <a href="/yeu-cau" class="text-primary text-[13px] no-underline hover:underline font-semibold flex items-center gap-1">Xem tất cả <span class="material-symbols-outlined text-[16px]">arrow_forward</span></a>
  </div>
  <% if (yeuCauList && yeuCauList.length > 0) { %>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      <% yeuCauList.forEach(function(yc, index) { %>
        <a href="/yeu-cau" class="card no-underline text-on-surface block animate-on-scroll group" style="transition-delay: <%= (index % 3) * 80 %>ms">
          <div class="flex items-start justify-between mb-3">
            <span class="badge badge-open">Đang mở</span>
            <span class="text-[11px] text-on-surface-variant"><%= new Date(yc.ngay_yeu_cau).toLocaleDateString('vi-VN') %></span>
          </div>
          <h3 class="text-[15px] font-semibold mb-2 group-hover:text-primary transition-colors line-clamp-1"><%= yc.tieu_de %></h3>
          <p class="text-[13px] text-on-surface-variant mb-4 line-clamp-2 leading-relaxed"><%= yc.mo_ta || 'Không có mô tả' %></p>
          <div class="flex items-center justify-between pt-3 border-t border-outline-variant/40">
            <span class="text-[12px] text-on-surface-variant"><%= yc.hinh_thuc_hoc %> · <%= yc.so_buoi_tuan %> buổi/tuần</span>
            <span class="text-[14px] font-bold text-primary"><%= Math.round(Number(yc.tien_hoc_phi) / 1000) %>k/buổi</span>
          </div>
        </a>
      <% }); %>
    </div>
  <% } else { %>
    <div class="card text-center py-12">
      <span class="material-symbols-outlined text-[40px] text-on-surface-variant/40 block mb-3">search_off</span>
      <p class="text-on-surface-variant">Chưa có yêu cầu nào đang mở.</p>
    </div>
  <% } %>
</section>

<!-- Gia sư nổi bật -->
<section class="max-w-[1280px] mx-auto px-4 md:px-10 pb-14">
  <div class="flex items-center justify-between mb-7 animate-on-scroll">
    <div>
      <h2 class="text-[1.6rem] font-bold text-on-surface">Gia sư tiêu biểu</h2>
      <p class="text-[13px] text-on-surface-variant mt-0.5">Đang sẵn sàng nhận lớp</p>
    </div>
  </div>
  <% if (giaSuList && giaSuList.length > 0) { %>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
      <% giaSuList.forEach(function(gs, index) { %>
        <a href="/ho-so-gia-su/<%= gs.ma_gia_su %>" class="card text-center no-underline text-on-surface block animate-on-scroll group" style="transition-delay: <%= (index % 4) * 80 %>ms">
          <div class="w-14 h-14 rounded-full bg-gradient-to-br from-primary to-primary/70 text-white flex items-center justify-center text-xl font-bold mx-auto mb-3 group-hover:scale-110 transition-transform shadow-lg shadow-primary/20">
            <%= gs.ho_ten.charAt(0) %>
          </div>
          <h3 class="text-[14px] font-semibold group-hover:text-primary transition-colors"><%= gs.ho_ten %></h3>
          <p class="text-[12px] text-on-surface-variant mt-1 mb-2"><%= gs.trinh_do || 'Chưa cập nhật' %></p>
          <span class="badge badge-open">
            <span class="status-dot status-dot-green"></span>Trống lịch
          </span>
        </a>
      <% }); %>
    </div>
  <% } else { %>
    <p class="text-on-surface-variant text-center py-8">Chưa có gia sư nào.</p>
  <% } %>
</section>

<!-- Cách hoạt động -->
<section class="max-w-[1280px] mx-auto px-4 md:px-10 pb-20">
  <div class="text-center mb-10 animate-on-scroll">
    <h2 class="text-[1.6rem] font-bold text-on-surface">Cách hoạt động</h2>
    <p class="text-[13px] text-on-surface-variant mt-1">3 bước đơn giản để bắt đầu</p>
  </div>
  <div class="grid md:grid-cols-3 gap-6">
    <div class="card text-center animate-on-scroll relative overflow-hidden group">
      <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-primary to-primary/50 rounded-t-2xl"></div>
      <div class="w-14 h-14 rounded-2xl bg-primary/10 text-primary flex items-center justify-center text-2xl font-bold mx-auto mb-5 group-hover:bg-primary group-hover:text-white transition-all">1</div>
      <h3 class="text-[15px] font-semibold mb-2">Đăng yêu cầu</h3>
      <p class="text-[13px] text-on-surface-variant leading-relaxed">Học viên đăng yêu cầu tìm gia sư với môn học, thời gian, học phí mong muốn.</p>
    </div>
    <div class="card text-center animate-on-scroll delay-100 relative overflow-hidden group">
      <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-secondary to-secondary/50 rounded-t-2xl"></div>
      <div class="w-14 h-14 rounded-2xl bg-secondary/10 text-secondary flex items-center justify-center text-2xl font-bold mx-auto mb-5 group-hover:bg-secondary group-hover:text-white transition-all">2</div>
      <h3 class="text-[15px] font-semibold mb-2">Gia sư ứng tuyển</h3>
      <p class="text-[13px] text-on-surface-variant leading-relaxed">Nhiều gia sư phù hợp sẽ ứng tuyển, gửi lời nhắn và mong muốn của họ.</p>
    </div>
    <div class="card text-center animate-on-scroll delay-200 relative overflow-hidden group">
      <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-primary to-secondary rounded-t-2xl"></div>
      <div class="w-14 h-14 rounded-2xl bg-primary/10 text-primary flex items-center justify-center text-2xl font-bold mx-auto mb-5 group-hover:bg-primary group-hover:text-white transition-all">3</div>
      <h3 class="text-[15px] font-semibold mb-2">Chọn gia sư</h3>
      <p class="text-[13px] text-on-surface-variant leading-relaxed">Xem hồ sơ và chọn gia sư phù hợp nhất. Lớp học được tạo tự động.</p>
    </div>
  </div>
</section>

<!-- Auth Modal -->
<div id="authModal" class="hidden fixed inset-0 z-[100] flex items-center justify-center bg-black/40 backdrop-blur-sm" onclick="if(event.target===this)closeAuthModal()">
  <div class="glass-panel rounded-2xl p-6 w-full max-w-md mx-4 max-h-[90vh] overflow-y-auto" onclick="event.stopPropagation()">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-headline-md" id="authModalTitle">Đăng nhập</h2>
      <button onclick="closeAuthModal()" class="text-on-surface-variant hover:text-on-surface">
        <span class="material-symbols-outlined">close</span>
      </button>
    </div>

    <!-- Tabs -->
    <div class="flex gap-0 mb-6 bg-surface-container-low rounded-xl p-1">
      <button id="tabLogin" onclick="switchAuthTab('login')" class="flex-1 py-2.5 text-center rounded-lg text-label-md font-semibold transition-colors bg-primary-container text-on-primary-container">Đăng nhập</button>
      <button id="tabRegister" onclick="switchAuthTab('register')" class="flex-1 py-2.5 text-center rounded-lg text-label-md font-semibold transition-colors text-on-surface-variant">Đăng ký</button>
    </div>

    <!-- Login Form -->
    <div id="loginPanel" class="tab-content active">
      <form action="/auth/login" method="POST" class="space-y-4">
        <div>
          <label class="text-label-md text-on-surface-variant block mb-1">Email</label>
          <input type="email" name="email" required class="w-full px-3 py-2 border border-outline-variant rounded-lg bg-surface-container-lowest text-on-surface"/>
        </div>
        <div>
          <label class="text-label-md text-on-surface-variant block mb-1">Mật khẩu</label>
          <input type="password" name="password" required class="w-full px-3 py-2 border border-outline-variant rounded-lg bg-surface-container-lowest text-on-surface"/>
          <div class="text-right mt-1">
            <a href="#" onclick="switchAuthTab('forgot'); return false;" class="text-label-sm text-primary hover:underline">Quên mật khẩu?</a>
          </div>
        </div>
        <button type="submit" class="btn-primary w-full py-2.5">Đăng nhập</button>
      </form>
    </div>

    <!-- Forgot Password Panel -->
    <div id="forgotPanel" class="tab-content">
      <div class="mb-4 text-body-md text-on-surface-variant">
        Nhập email của bạn để nhận liên kết đặt lại mật khẩu.
      </div>
      <form action="/auth/forgot-password" method="POST" class="space-y-4" id="forgotPasswordForm">
        <div>
          <label class="text-label-md text-on-surface-variant block mb-1">Email</label>
          <input type="email" name="email" required class="w-full px-3 py-2 border border-outline-variant rounded-lg bg-surface-container-lowest text-on-surface"/>
        </div>
        <button type="submit" id="forgotSubmitBtn" class="btn-primary w-full py-2.5 flex justify-center items-center gap-2">
          <span>Gửi liên kết</span>
          <span class="material-symbols-outlined hidden animate-spin" id="forgotSpinner">progress_activity</span>
        </button>
        <div class="text-center mt-2">
          <a href="#" onclick="switchAuthTab('login'); return false;" class="text-label-sm text-on-surface-variant hover:underline">Quay lại đăng nhập</a>
        </div>
      </form>
    </div>

    <!-- Register Panel -->
    <div id="registerPanel" class="tab-content">
      <!-- Role Cards -->
      <div class="grid grid-cols-2 gap-3 mb-5">
        <button type="button" id="roleCardHocVien" onclick="selectRegisterRole('hoc_vien')" class="p-4 rounded-xl border-2 border-outline-variant bg-surface-container-lowest text-on-surface hover:border-primary transition-all text-left">
          <span class="material-symbols-outlined text-3xl text-primary mb-2 block">school</span>
          <h3 class="text-body-lg font-semibold mb-1">Học viên</h3>
          <p class="text-label-sm text-on-surface-variant">Tìm gia sư phù hợp</p>
        </button>
        <button type="button" id="roleCardGiaSu" onclick="selectRegisterRole('gia_su')" class="p-4 rounded-xl border-2 border-outline-variant bg-surface-container-lowest text-on-surface hover:border-secondary transition-all text-left">
          <span class="material-symbols-outlined text-3xl text-secondary mb-2 block">person_book</span>
          <h3 class="text-body-lg font-semibold mb-1">Gia sư</h3>
          <p class="text-label-sm text-on-surface-variant">Nhận lớp dạy phù hợp</p>
        </button>
      </div>

      <form action="/auth/register" method="POST" class="space-y-4" id="registerForm">
        <input type="hidden" name="role" id="registerRoleInput" value=""/>
        <div>
          <label class="text-label-md text-on-surface-variant block mb-1">Họ tên</label>
          <input type="text" name="ho_ten" required class="w-full px-3 py-2 border border-outline-variant rounded-lg bg-surface-container-lowest text-on-surface"/>
        </div>
        <div>
          <label class="text-label-md text-on-surface-variant block mb-1">Email</label>
          <input type="email" name="email" required class="w-full px-3 py-2 border border-outline-variant rounded-lg bg-surface-container-lowest text-on-surface"/>
        </div>
        <div>
          <label class="text-label-md text-on-surface-variant block mb-1">Mật khẩu</label>
          <input type="password" name="password" required class="w-full px-3 py-2 border border-outline-variant rounded-lg bg-surface-container-lowest text-on-surface"/>
        </div>
        <div>
          <label class="text-label-md text-on-surface-variant block mb-1">Số điện thoại</label>
          <input type="text" name="so_dien_thoai" class="w-full px-3 py-2 border border-outline-variant rounded-lg bg-surface-container-lowest text-on-surface"/>
        </div>
        <button type="submit" id="registerSubmitBtn" class="btn-secondary w-full py-2.5 opacity-50 cursor-not-allowed" disabled>Chọn vai trò để đăng ký</button>
      </form>
    </div>
  </div>
</div>

<script>
  let selectedRole = '';

  function openAuthModal(tab) {
    document.getElementById('authModal').classList.remove('hidden');
    switchAuthTab(tab || 'login');
  }

  function closeAuthModal() { document.getElementById('authModal').classList.add('hidden'); }

  function switchAuthTab(tab) {
    const tabLogin = document.getElementById('tabLogin');
    const tabRegister = document.getElementById('tabRegister');
    const loginPanel = document.getElementById('loginPanel');
    const registerPanel = document.getElementById('registerPanel');
    const forgotPanel = document.getElementById('forgotPanel');

    // Reset all
    loginPanel.classList.remove('active');
    registerPanel.classList.remove('active');
    if (forgotPanel) forgotPanel.classList.remove('active');
    
    tabLogin.className = 'flex-1 py-2.5 text-center rounded-lg text-label-md font-semibold transition-colors text-on-surface-variant hover:bg-surface-variant';
    tabRegister.className = 'flex-1 py-2.5 text-center rounded-lg text-label-md font-semibold transition-colors text-on-surface-variant hover:bg-surface-variant';

    if (tab === 'login') {
      tabLogin.className = 'flex-1 py-2.5 text-center rounded-lg text-label-md font-semibold transition-colors bg-primary-container text-on-primary-container';
      loginPanel.classList.add('active');
      document.getElementById('authModalTitle').textContent = 'Đăng nhập';
    } else if (tab === 'register') {
      tabRegister.className = 'flex-1 py-2.5 text-center rounded-lg text-label-md font-semibold transition-colors bg-primary-container text-on-primary-container';
      registerPanel.classList.add('active');
      document.getElementById('authModalTitle').textContent = 'Đăng ký';
    } else if (tab === 'forgot') {
      if (forgotPanel) forgotPanel.classList.add('active');
      document.getElementById('authModalTitle').textContent = 'Quên mật khẩu';
    }
  }

  function selectRegisterRole(role) {
    selectedRole = role;
    document.getElementById('registerRoleInput').value = role;

    const cardHV = document.getElementById('roleCardHocVien');
    const cardGS = document.getElementById('roleCardGiaSu');
    const submitBtn = document.getElementById('registerSubmitBtn');

    // Reset borders
    cardHV.style.borderColor = '#c3c6d6'; cardHV.style.borderWidth = '2px';
    cardGS.style.borderColor = '#c3c6d6'; cardGS.style.borderWidth = '2px';

    if (role === 'hoc_vien') {
      cardHV.style.borderColor = '#0040a1'; cardHV.style.borderWidth = '2px';
      submitBtn.className = 'btn-primary w-full py-2.5';
      submitBtn.textContent = 'Đăng ký làm Học viên';
    } else {
      cardGS.style.borderColor = '#006b5c'; cardGS.style.borderWidth = '2px';
      submitBtn.className = 'btn-secondary w-full py-2.5';
      submitBtn.textContent = 'Đăng ký làm Gia sư';
    }

    submitBtn.disabled = false;
    submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
  }

  // Handle forgot password form submit
  document.getElementById('forgotPasswordForm')?.addEventListener('submit', function() {
    const btn = document.getElementById('forgotSubmitBtn');
    const spinner = document.getElementById('forgotSpinner');
    if (btn && spinner) {
      btn.disabled = true;
      btn.classList.add('opacity-70', 'cursor-not-allowed');
      spinner.classList.remove('hidden');
    }
  });
</script>

<script>
  // IntersectionObserver for scroll animations
  document.addEventListener("DOMContentLoaded", () => {
    const observer = new IntersectionObserver((entries, obs) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          obs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));

    // Stat numbers animate on first visible
    document.querySelectorAll('.stat-number').forEach((el, i) => {
      el.style.animationDelay = `${i * 80}ms`;
    });
  });
</script>

<%- include('partials/footer') %>
