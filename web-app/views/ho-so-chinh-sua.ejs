<%- include('partials/header', { title: 'Chỉnh sửa hồ sơ' }) %>
<%- include('partials/navbar') %>

<section class="max-w-[800px] mx-auto px-4 md:px-10 pt-8 pb-16">
  <% if (error) { %>
    <div class="bg-error-container text-error px-4 py-3 rounded-lg text-body-md mb-4"><%= error %></div>
  <% } %>

  <div class="flex items-center gap-3 mb-6">
    <a href="/" class="btn-icon" aria-label="Quay lại">
      <span class="material-symbols-outlined">arrow_back</span>
    </a>
    <h1 class="text-headline-md text-on-surface">Chỉnh sửa hồ sơ</h1>
  </div>

  <div class="card p-8">
    <form action="/ho-so/chinh-sua" method="POST" class="space-y-5">
      
      <!-- Thông tin chung -->
      <div>
        <label class="text-label-md font-semibold text-on-surface block mb-1">Họ và tên</label>
        <input type="text" name="ho_ten" value="<%= profile.ho_ten %>" required class="w-full px-4 py-3 rounded-xl border border-outline-variant bg-surface-container-lowest focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors"/>
      </div>
      
      <div class="grid md:grid-cols-2 gap-5">
        <div>
          <label class="text-label-md font-semibold text-on-surface block mb-1">Ngày sinh</label>
          <input type="date" name="ngay_sinh" value="<%= profile.ngay_sinh ? profile.ngay_sinh.split('T')[0] : '' %>" class="w-full px-4 py-3 rounded-xl border border-outline-variant bg-surface-container-lowest focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors"/>
        </div>
        <div>
          <label class="text-label-md font-semibold text-on-surface block mb-1">Số điện thoại</label>
          <input type="tel" name="so_dien_thoai" value="<%= profile.so_dien_thoai || '' %>" class="w-full px-4 py-3 rounded-xl border border-outline-variant bg-surface-container-lowest focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors"/>
        </div>
      </div>

      <!-- Thông tin theo Role -->
      <% if (isGiaSu) { %>
        <div>
          <label class="text-label-md font-semibold text-on-surface block mb-1">Trình độ hiện tại</label>
          <input type="text" name="trinh_do" value="<%= profile.trinh_do || '' %>" placeholder="VD: Sinh viên năm 3 ĐH Bách Khoa, Giáo viên tự do..." class="w-full px-4 py-3 rounded-xl border border-outline-variant bg-surface-container-lowest focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors"/>
        </div>
      <% } else { %>
        <div>
          <label class="text-label-md font-semibold text-on-surface block mb-1">Khối/Lớp hiện tại</label>
          <input type="text" name="khoi_hien_tai" value="<%= profile.khoi_hien_tai || '' %>" placeholder="VD: Lớp 10, Lớp 12, Ôn thi Đại học..." class="w-full px-4 py-3 rounded-xl border border-outline-variant bg-surface-container-lowest focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors"/>
        </div>
      <% } %>

      <% if (isGiaSu) { %>
      <div>
        <label class="text-label-md font-semibold text-on-surface block mb-1">Giới thiệu bản thân</label>
        <textarea name="gioi_thieu" rows="4" placeholder="Mô tả kinh nghiệm giảng dạy, thành tích học tập..." class="w-full px-4 py-3 rounded-xl border border-outline-variant bg-surface-container-lowest focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors resize-none"><%= profile.gioi_thieu || '' %></textarea>
      </div>
      <% } %>

      <div class="pt-4 border-t border-outline-variant flex justify-end gap-3">
        <a href="/" class="btn-outline no-underline px-6 py-3">Hủy</a>
        <button type="submit" class="btn-primary px-6 py-3 shadow-md">Lưu thay đổi</button>
      </div>
    </form>
  </div>
</section>

<%- include('partials/footer') %>
