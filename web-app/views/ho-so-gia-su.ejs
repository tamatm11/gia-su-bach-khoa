<%- include('partials/header', { title: gs.ho_ten }) %>
<%- include('partials/navbar') %>

<section class="max-w-[1280px] mx-auto px-4 md:px-10 pt-8 pb-16">
  <% if (error) { %>
    <div class="bg-error-container text-error px-4 py-3 rounded-lg text-body-md mb-4"><%= error %></div>
  <% } %>

  <!-- Profile Header -->
  <div class="glass-panel rounded-2xl p-6 md:p-8 mb-6">
    <div class="flex flex-col md:flex-row items-start gap-6">
      <!-- Avatar -->
      <div class="w-20 h-20 rounded-full bg-primary-container text-on-primary-container flex items-center justify-center text-3xl font-bold shrink-0" role="img" aria-label="Ảnh đại diện: <%= gs.ho_ten %>">
        <%= gs.ho_ten.charAt(0) %>
      </div>
      <div class="flex-1">
        <div class="flex flex-wrap items-center gap-3 mb-2">
          <h1 class="text-headline-md text-on-surface"><%= gs.ho_ten %></h1>
          <span class="badge <%= gs.trong_lich ? 'badge-open' : 'badge-closed' %>">
            <span class="status-dot <%= gs.trong_lich ? 'status-dot-green' : 'status-dot-yellow' %>"></span>
            <%= gs.trong_lich ? 'Đang trống lịch' : 'Đang bận' %>
          </span>
        </div>
        <p class="text-body-lg text-primary font-medium mb-3"><%= gs.trinh_do || 'Chưa cập nhật trình độ' %></p>
        <% if (gs.gioi_thieu) { %>
          <p class="text-body-md text-on-surface-variant leading-relaxed"><%= gs.gioi_thieu %></p>
        <% } %>
      </div>
    </div>

    <!-- Stats Row -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-6 pt-6 border-t border-outline-variant">
      <div class="text-center">
        <div class="text-2xl font-bold text-primary"><%= gs.so_lop_da_nhan || 0 %></div>
        <div class="text-label-sm text-on-surface-variant">Lớp đã nhận</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold text-secondary"><%= gs.so_lop_dang_day || 0 %></div>
        <div class="text-label-sm text-on-surface-variant">Đang dạy</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold text-primary">
          <%= gs.diem_danh_gia_tb ? Number(gs.diem_danh_gia_tb).toFixed(1) : 'N/A' %>
          <span class="text-yellow-500 text-lg">&#9733;</span>
        </div>
        <div class="text-label-sm text-on-surface-variant">Điểm đánh giá</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold text-secondary"><%= danhGia.length %></div>
        <div class="text-label-sm text-on-surface-variant">Lượt đánh giá</div>
      </div>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-6">
    <!-- Left Column: Môn dạy + Đánh giá -->
    <div class="space-y-6">
      <!-- Môn dạy -->
      <div class="glass-panel rounded-2xl p-6">
        <h2 class="text-body-lg font-semibold mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-primary">menu_book</span> Môn dạy
        </h2>
        <% if (monHoc.length > 0) { %>
          <div class="flex flex-wrap gap-2">
            <% monHoc.forEach(function(mh) { %>
              <span class="badge badge-active text-sm px-4 py-2">
                <%= mh.mon_hoc ? mh.mon_hoc.ten_mon : mh.ma_mon %>
              </span>
            <% }); %>
          </div>
        <% } else { %>
          <p class="text-body-md text-on-surface-variant">Chưa cập nhật môn dạy.</p>
        <% } %>
      </div>

      <!-- Đánh giá -->
      <div class="glass-panel rounded-2xl p-6">
        <h2 class="text-body-lg font-semibold mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-primary">star</span> Đánh giá từ học viên
        </h2>
        <% if (danhGia.length > 0) { %>
          <div class="space-y-4">
            <% danhGia.forEach(function(dg) { %>
              <div class="pb-4 border-b border-outline-variant last:border-0 last:pb-0">
                <div class="flex items-center justify-between mb-1">
                  <span class="text-label-md font-semibold">
                    <%= dg.dang_ky && dg.dang_ky.lop_hoc && dg.dang_ky.lop_hoc.hoc_vien ? dg.dang_ky.lop_hoc.hoc_vien.ho_ten : 'Ẩn danh' %>
                  </span>
                  <span class="text-yellow-500 text-label-sm">
                    <% for (var i = 0; i < dg.diem_sao; i++) { %>&#9733;<% } %>
                    <% for (var i = dg.diem_sao; i < 5; i++) { %>&#9734;<% } %>
                  </span>
                </div>
                <% if (dg.nhan_xet) { %>
                  <p class="text-body-md text-on-surface-variant"><%= dg.nhan_xet %></p>
                <% } %>
                <p class="text-label-sm text-on-surface-variant mt-1"><%= new Date(dg.ngay_danh_gia).toLocaleDateString('vi-VN') %></p>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <p class="text-body-md text-on-surface-variant">Chưa có đánh giá nào.</p>
        <% } %>
      </div>
    </div>

    <!-- Right Column: Lớp đang dạy + Đã hoàn thành -->
    <div class="space-y-6">
      <!-- Lớp đang dạy -->
      <div class="glass-panel rounded-2xl p-6">
        <h2 class="text-body-lg font-semibold mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-secondary">play_circle</span> Lớp đang dạy
        </h2>
        <% if (lopDangDay.length > 0) { %>
          <div class="space-y-3">
            <% lopDangDay.forEach(function(lop) { %>
              <div class="p-3 rounded-xl bg-surface-container-low">
                <div class="flex items-center justify-between mb-1">
                  <span class="font-mono text-label-sm"><%= lop.ma_lop %></span>
                  <span class="badge badge-active">Đang học</span>
                </div>
                <p class="text-label-md">Học viên: <strong><%= lop.hoc_vien ? lop.hoc_vien.ho_ten : 'N/A' %></strong></p>
                <p class="text-label-sm text-on-surface-variant mt-1">
                  Bắt đầu: <%= lop.ngay_bat_dau ? new Date(lop.ngay_bat_dau).toLocaleDateString('vi-VN') : 'N/A' %> · <%= lop.tong_so_buoi || 0 %> buổi
                </p>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <p class="text-body-md text-on-surface-variant">Không có lớp đang dạy.</p>
        <% } %>
      </div>

      <!-- Lớp đã hoàn thành -->
      <div class="glass-panel rounded-2xl p-6">
        <h2 class="text-body-lg font-semibold mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-secondary">check_circle</span> Lớp đã hoàn thành
        </h2>
        <% if (lopDaDay.length > 0) { %>
          <div class="space-y-3">
            <% lopDaDay.forEach(function(lop) { %>
              <div class="p-3 rounded-xl bg-surface-container-low">
                <div class="flex items-center justify-between mb-1">
                  <span class="font-mono text-label-sm"><%= lop.ma_lop %></span>
                  <span class="badge badge-open">Hoàn thành</span>
                </div>
                <p class="text-label-md">Học viên: <strong><%= lop.hoc_vien ? lop.hoc_vien.ho_ten : 'N/A' %></strong></p>
                <p class="text-label-sm text-on-surface-variant mt-1">
                  Bắt đầu: <%= lop.ngay_bat_dau ? new Date(lop.ngay_bat_dau).toLocaleDateString('vi-VN') : 'N/A' %> · <%= lop.tong_so_buoi || 0 %> buổi
                </p>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <p class="text-body-md text-on-surface-variant">Chưa có lớp hoàn thành.</p>
        <% } %>
      </div>
    </div>
  </div>
  
  <% if (ma_yeu_cau && role === 'hoc_vien') { %>
    <div class="fixed bottom-0 left-0 right-0 bg-surface-container-lowest border-t border-outline-variant p-4 z-50 shadow-[0_-4px_16px_rgba(0,0,0,0.1)]">
      <div class="max-w-[1280px] mx-auto flex flex-wrap items-center justify-between gap-4">
        <div>
          <h4 class="text-title-md font-bold text-on-surface">Bạn muốn duyệt gia sư này?</h4>
          <p class="text-label-sm text-on-surface-variant">Hệ thống sẽ tự động tạo lớp học và lưu lịch giảng dạy.</p>
        </div>
        <button type="button" 
                class="btn-primary h-[48px] shrink-0 btn-mo-duyet" 
                data-ma-yeu-cau="<%= ma_yeu_cau %>"
                data-ma-gia-su="<%= gs.ma_gia_su %>"
                data-ho-ten="<%= gs.ho_ten %>"
                data-so-buoi-tuan="<%= yc ? yc.so_buoi_tuan : 2 %>"
                style="padding: 0 24px; font-size: 16px;">
          <span class="material-symbols-outlined align-middle mr-1 text-[20px]">check_circle</span>
          Chọn gia sư & Tạo lớp
        </button>
      </div>
    </div>

    <!-- Modal Duyệt Gia Sư -->
    <div id="duyetModal" class="hidden fixed inset-0 z-[100] flex items-center justify-center bg-black/40 backdrop-blur-sm">
      <div class="glass-panel rounded-2xl p-6 w-full max-w-md mx-4 max-h-[90vh] overflow-y-auto">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-headline-md">Xác nhận duyệt gia sư</h3>
          <button onclick="closeDuyetModal()" class="text-on-surface-variant hover:text-on-surface">
            <span class="material-symbols-outlined">close</span>
          </button>
        </div>
        <form action="/chon-gia-su" method="POST">
          <input type="hidden" name="ma_yeu_cau" id="duyetMaYeuCau"/>
          <input type="hidden" name="ma_gia_su" id="duyetMaGiaSu"/>
          <div class="space-y-4 text-left">
            <p class="text-body-md text-on-surface-variant mb-2">Bạn đang duyệt gia sư <strong id="duyetTenGiaSu" class="text-primary"></strong>. Vui lòng chọn thời gian và lịch học cụ thể:</p>
            
            <div>
              <label class="text-label-sm text-on-surface-variant block mb-1 font-medium">Ngày bắt đầu dự kiến</label>
              <input type="date" name="ngay_bat_dau" id="duyetNgayBatDau" required class="w-full px-3 py-2 border border-outline-variant rounded-lg bg-surface-container-lowest text-on-surface"/>
            </div>
            <div>
              <label class="text-label-sm text-on-surface-variant block mb-1 font-medium">Tổng số buổi</label>
              <input type="number" name="tong_so_buoi" value="24" required min="1" class="w-full px-3 py-2 border border-outline-variant rounded-lg bg-surface-container-lowest text-on-surface"/>
            </div>

            <div>
              <label class="text-label-sm text-on-surface-variant block mb-2 font-semibold">Lịch học trong tuần (chọn cụ thể)</label>
              <div id="duyetLichHocContainer" class="space-y-3">
                <!-- Sinh động bằng Javascript -->
              </div>
            </div>
            
            <button type="submit" class="btn-primary w-full mt-2">Duyệt & Tạo lớp học</button>
          </div>
        </form>
      </div>
    </div>
    <script>
      document.querySelectorAll('.btn-mo-duyet').forEach(btn => {
        btn.addEventListener('click', function() {
          const maYc = this.getAttribute('data-ma-yeu-cau');
          const maGs = this.getAttribute('data-ma-gia-su');
          const tenGs = this.getAttribute('data-ho-ten');
          const soBuoiTuan = this.getAttribute('data-so-buoi-tuan');
          openDuyetModal(maYc, maGs, tenGs, soBuoiTuan);
        });
      });

      function openDuyetModal(maYc, maGs, tenGs, soBuoiTuan) {
        document.getElementById('duyetMaYeuCau').value = maYc;
        document.getElementById('duyetMaGiaSu').value = maGs;
        document.getElementById('duyetTenGiaSu').textContent = tenGs;
        
        // Set default date to tomorrow
        const tomorrow = new Date();
        tomorrow.setDate(tomorrow.getDate() + 1);
        document.getElementById('duyetNgayBatDau').value = tomorrow.toISOString().split('T')[0];

        // Sinh bộ chọn lịch học động dựa trên soBuoiTuan
        const container = document.getElementById('duyetLichHocContainer');
        container.innerHTML = '';
        const defaultDays = [2, 4, 6, 3, 5, 7, 1]; // T2, T4, T6, T3, T5, T7, CN
        const parsedSoBuoiTuan = parseInt(soBuoiTuan) || 2;
        for (let i = 0; i < parsedSoBuoiTuan; i++) {
          const defaultDay = defaultDays[i % defaultDays.length];
          const slotHtml = `
            <div class="grid grid-cols-3 gap-2 items-center bg-surface-container-low p-2 rounded-lg border border-outline-variant">
              <div>
                <label class="text-[10px] text-on-surface-variant block mb-0.5 font-medium">Buổi ${i + 1} (Thứ)</label>
                <select name="thu_trong_tuan" required class="w-full px-2 py-1.5 border border-outline-variant rounded bg-surface-container-lowest text-on-surface text-xs h-[32px]">
                  <option value="2" ${defaultDay === 2 ? 'selected' : ''}>Thứ 2</option>
                  <option value="3" ${defaultDay === 3 ? 'selected' : ''}>Thứ 3</option>
                  <option value="4" ${defaultDay === 4 ? 'selected' : ''}>Thứ 4</option>
                  <option value="5" ${defaultDay === 5 ? 'selected' : ''}>Thứ 5</option>
                  <option value="6" ${defaultDay === 6 ? 'selected' : ''}>Thứ 6</option>
                  <option value="7" ${defaultDay === 7 ? 'selected' : ''}>Thứ 7</option>
                  <option value="1" ${defaultDay === 1 ? 'selected' : ''}>Chủ nhật</option>
                </select>
              </div>
              <div>
                <label class="text-[10px] text-on-surface-variant block mb-0.5 font-medium">Bắt đầu</label>
                <input type="time" name="gio_bat_dau" value="18:00" required class="w-full px-2 py-1.5 border border-outline-variant rounded bg-surface-container-lowest text-on-surface text-xs h-[32px]"/>
              </div>
              <div>
                <label class="text-[10px] text-on-surface-variant block mb-0.5 font-medium">Kết thúc</label>
                <input type="time" name="gio_ket_thuc" value="20:00" required class="w-full px-2 py-1.5 border border-outline-variant rounded bg-surface-container-lowest text-on-surface text-xs h-[32px]"/>
              </div>
            </div>
          `;
          container.insertAdjacentHTML('beforeend', slotHtml);
        }
        
        document.getElementById('duyetModal').classList.remove('hidden');
      }
      function closeDuyetModal() {
        document.getElementById('duyetModal').classList.add('hidden');
      }
    </script>
</section>

<%- include('partials/footer') %>
