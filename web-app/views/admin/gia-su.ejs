<!DOCTYPE html>
<html class="light" lang="vi">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>Quản lý Gia sư - Admin - Gia Sư Bách Khoa</title>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <style>
    .glass-panel {
      background-color: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.5);
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.04);
    }
    .badge {
      display: inline-flex; align-items: center; padding: 4px 12px;
      border-radius: 999px; font-size: 12px; font-weight: 600;
    }
    .badge-open { background: #e5f7ed; color: #006b5c; }
    .badge-closed { background: #fff3cd; color: #856404; }
    .sidebar-link {
      display: flex; align-items: center; gap: 12px; padding: 10px 16px;
      border-radius: 12px; color: #424654; font-size: 14px; font-weight: 500;
      transition: all 0.15s; text-decoration: none;
    }
    .sidebar-link:hover { background: #eff4ff; color: #0040a1; }
    .sidebar-link.active { background: #dae2ff; color: #0040a1; font-weight: 600; }
    table { width: 100%; border-collapse: collapse; }
    th { text-align: left; padding: 12px 16px; font-size: 12px; font-weight: 600;
         color: #424654; text-transform: uppercase; letter-spacing: 0.05em;
         border-bottom: 1px solid #c3c6d6; }
    td { padding: 12px 16px; font-size: 14px; border-bottom: 1px solid #e5eeff; }
    tr:hover td { background: #f8f9ff; }
    select, input { outline: none; }
    select:focus, input:focus { border-color: #0040a1; }
  </style>
</head>
<body class="bg-[#f8f9ff] text-[#0b1c30] antialiased">
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="w-64 bg-white border-r border-[#c3c6d6] flex flex-col fixed top-0 left-0 h-full z-40">
      <div class="p-6 border-b border-[#c3c6d6]">
        <a href="/" class="flex items-center gap-2 no-underline">
          <span class="material-symbols-outlined text-[#0040a1] text-2xl">school</span>
          <span class="text-lg font-bold text-[#0b1c30]">Gia Sư BK</span>
        </a>
        <p class="text-sm text-[#424654] mt-1">Admin Panel</p>
      </div>
      <nav class="flex-1 p-4 space-y-1">
        <a href="/admin" class="sidebar-link">
          <span class="material-symbols-outlined text-[20px]">dashboard</span> Tổng quan
        </a>
        <a href="/admin/yeu-cau" class="sidebar-link">
          <span class="material-symbols-outlined text-[20px]">description</span> Yêu cầu lớp
        </a>
        <a href="/admin/lop-hoc" class="sidebar-link">
          <span class="material-symbols-outlined text-[20px]">collections_bookmark</span> Lớp học
        </a>
        <a href="/admin/gia-su" class="sidebar-link active">
          <span class="material-symbols-outlined text-[20px]">person_book</span> Gia sư
        </a>
        <a href="/admin/hoc-vien" class="sidebar-link">
          <span class="material-symbols-outlined text-[20px]">group</span> Học viên
        </a>
      </nav>
      <div class="p-4 border-t border-[#c3c6d6]">
        <div class="flex items-center gap-3 mb-3">
          <span class="material-symbols-outlined text-[#424654]">person</span>
          <span class="text-sm text-[#424654]"><%= user.ho_ten %></span>
        </div>
        <a href="/" class="sidebar-link text-sm">
          <span class="material-symbols-outlined text-[18px]">arrow_back</span> Về trang chủ
        </a>
        <form method="POST" action="/auth/logout" class="m-0">
          <button type="submit" class="sidebar-link text-sm text-[#ba1a1a] mt-1 hover:bg-[#ffdad6] w-full text-left bg-transparent border-0 cursor-pointer">
            <span class="material-symbols-outlined text-[18px]">logout</span> Đăng xuất
          </button>
        </form>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 ml-64 p-8">
      <% if (error) { %>
        <div class="bg-[#ffdad6] text-[#ba1a1a] px-4 py-3 rounded-lg text-base mb-6"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="bg-[#68fadd] text-[#007261] px-4 py-3 rounded-lg text-base mb-6"><%= success %></div>
      <% } %>

      <h1 class="text-3xl font-bold text-[#0b1c30] mb-2">Quản lý Gia sư</h1>
      <p class="text-base text-[#424654] mb-6">Danh sách tất cả gia sư trong hệ thống</p>

      <!-- Filter Bar -->
      <div class="glass-panel rounded-2xl p-4 mb-6">
        <form action="/admin/gia-su" method="GET" class="flex flex-wrap items-end gap-4">
          <div>
            <label class="text-sm text-[#424654] block mb-1">Tìm kiếm</label>
            <input type="text" name="search" value="<%= search %>" placeholder="Tên, Email hoặc Mã..." class="px-3 py-2 border border-[#c3c6d6] rounded-lg bg-white text-[#0b1c30] text-sm w-64"/>
          </div>
          <button type="submit" class="px-4 py-2 bg-[#0040a1] text-white rounded-lg text-sm font-medium">Tìm</button>
        </form>
      </div>

      <!-- Results Count -->
      <p class="text-sm text-[#424654] mb-4"><%= list.length %> gia sư được tìm thấy</p>

      <!-- Table -->
      <div class="glass-panel rounded-2xl overflow-hidden">
        <div class="overflow-x-auto">
          <table>
            <thead>
              <tr>
                <th>Mã GS</th>
                <th>Họ tên</th>
                <th>Email</th>
                <th>Trình độ</th>
                <th>Trạng thái lịch</th>
                <th>Ngày đăng ký</th>
              </tr>
            </thead>
            <tbody>
              <% if (list.length > 0) { %>
                <% list.forEach(function(gs) { %>
                  <tr>
                    <td class="font-mono text-sm"><%= gs.ma_gia_su %></td>
                    <td class="font-medium"><%= gs.ho_ten %></td>
                    <td><%= gs.email || 'N/A' %></td>
                    <td><%= gs.trinh_do || 'Chưa cập nhật' %></td>
                    <td><span class="badge <%= gs.trong_lich ? 'badge-open' : 'badge-closed' %>"><%= gs.trong_lich ? 'Trống lịch' : 'Bận' %></span></td>
                    <td><%= gs.ngay_dang_ky ? new Date(gs.ngay_dang_ky).toLocaleDateString('vi-VN') : 'N/A' %></td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr><td colspan="6" class="text-center text-[#424654] py-8">Không tìm thấy gia sư nào.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</body>
</html>
