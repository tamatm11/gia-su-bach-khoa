<!DOCTYPE html>
<html class="light" lang="vi">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>Nhật ký hệ thống - Admin - Gia Sư Bách Khoa</title>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "secondary-fixed": "#68fadd", "on-secondary-container": "#007261",
            "on-tertiary-fixed-variant": "#384953", "surface-tint": "#0056d2",
            "error-container": "#ffdad6", "outline-variant": "#c3c6d6",
            "tertiary": "#394953", "secondary-container": "#68fadd",
            "primary-fixed-dim": "#b2c5ff", "primary-fixed": "#dae2ff",
            "on-surface-variant": "#424654", "on-surface": "#0b1c30",
            "secondary-fixed-dim": "#44ddc1", "on-background": "#0b1c30",
            "on-secondary-fixed": "#00201a", "on-tertiary": "#ffffff",
            "inverse-on-surface": "#eaf1ff", "surface-bright": "#f8f9ff",
            "surface": "#f8f9ff", "surface-dim": "#cbdbf5",
            "primary-container": "#0056d2", "tertiary-fixed": "#d3e5f1",
            "error": "#ba1a1a", "surface-container": "#e5eeff",
            "surface-container-lowest": "#ffffff", "surface-container-highest": "#d3e4fe",
            "on-primary-fixed": "#001847", "on-primary": "#ffffff",
            "tertiary-container": "#50616b", "surface-container-high": "#dce9ff",
            "surface-container-low": "#eff4ff", "on-error": "#ffffff",
            "on-tertiary-fixed": "#0c1e26", "surface-variant": "#d3e4fe",
            "inverse-primary": "#b2c5ff", "outline": "#737785",
            "background": "#f8f9ff", "on-tertiary-container": "#cadce7",
            "secondary": "#006b5c", "on-primary-container": "#ccd8ff",
            "primary": "#0040a1", "on-secondary-fixed-variant": "#005145",
            "tertiary-fixed-dim": "#b7c9d5", "on-secondary": "#ffffff",
            "inverse-surface": "#213145", "on-primary-fixed-variant": "#0040a1"
          }
        }
      }
    }
  </script>
  <style>
    .glass-panel {
      background-color: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.5);
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.04);
    }
    .sidebar-link {
      display: flex; align-items: center; gap: 12px; padding: 10px 16px;
      border-radius: 12px; color: #424654; font-size: 14px; font-weight: 500;
      transition: all 0.15s; text-decoration: none;
    }
    .sidebar-link:hover { background: #eff4ff; color: #0040a1; }
    .sidebar-link.active { background: #dae2ff; color: #0040a1; font-weight: 600; }
    table { width: 100%; border-collapse: collapse; }
    th { text-align: left; padding: 12px 16px; font-size: 12px; font-weight: 600;
         color: #424654; text-transform: uppercase; letter-spacing: 0.05em;
         border-bottom: 1px solid #c3c6d6; }
    td { padding: 12px 16px; font-size: 14px; border-bottom: 1px solid #e5eeff; }
    tr:hover td { background: #f8f9ff; }
    
    .badge {
      display: inline-flex; align-items: center; padding: 4px 8px;
      border-radius: 6px; font-size: 11px; font-weight: 600; text-transform: uppercase;
    }
    .badge-insert { background: #e5f7ed; color: #006b5c; }
    .badge-update { background: #fff3e0; color: #e65100; }
    .badge-delete { background: #ffdad6; color: #ba1a1a; }
  </style>
</head>
<body class="bg-background text-on-surface antialiased">
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="w-64 bg-surface-container-lowest border-r border-outline-variant flex flex-col fixed top-0 left-0 h-full z-40">
      <div class="p-6 border-b border-outline-variant">
        <a href="/" class="flex items-center gap-2 no-underline">
          <span class="material-symbols-outlined text-primary text-2xl">school</span>
          <span class="text-body-lg font-bold text-on-surface">Gia Sư BK</span>
        </a>
        <p class="text-label-sm text-on-surface-variant mt-1">Admin Panel</p>
      </div>
      <nav class="flex-1 p-4 space-y-1">
        <a href="/admin" class="sidebar-link">
          <span class="material-symbols-outlined text-[20px]">dashboard</span> Tổng quan
        </a>
        <a href="/admin/yeu-cau" class="sidebar-link">
          <span class="material-symbols-outlined text-[20px]">description</span> Yêu cầu lớp
        </a>
        <a href="/admin/lop-hoc" class="sidebar-link">
          <span class="material-symbols-outlined text-[20px]">collections_bookmark</span> Lớp học
        </a>
        <a href="/admin/gia-su" class="sidebar-link">
          <span class="material-symbols-outlined text-[20px]">person_book</span> Gia sư
        </a>
        <a href="/admin/hoc-vien" class="sidebar-link">
          <span class="material-symbols-outlined text-[20px]">group</span> Học viên
        </a>
        <a href="/admin/audit-logs" class="sidebar-link active">
          <span class="material-symbols-outlined text-[20px]">history</span> Nhật ký hệ thống
        </a>
      </nav>
      <div class="p-4 border-t border-outline-variant">
        <div class="flex items-center gap-3 mb-3">
          <span class="material-symbols-outlined text-on-surface-variant">person</span>
          <span class="text-label-md text-on-surface-variant"><%= user.ho_ten %></span>
        </div>
        <a href="/" class="sidebar-link text-label-sm">
          <span class="material-symbols-outlined text-[18px]">arrow_back</span> Về trang chủ
        </a>
        <form method="POST" action="/auth/logout" class="m-0">
          <button type="submit" class="sidebar-link text-label-sm text-error mt-1 w-full text-left bg-transparent border-0 cursor-pointer">
            <span class="material-symbols-outlined text-[18px]">logout</span> Đăng xuất
          </button>
        </form>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 ml-64 p-8">
      <% if (error) { %>
        <div class="bg-error-container text-error px-4 py-3 rounded-lg text-body-md mb-6"><%= error %></div>
      <% } %>
      
      <div class="flex items-center justify-between mb-2">
        <h1 class="text-headline-md text-on-surface">Nhật ký hệ thống (Audit Logs)</h1>
      </div>
      <p class="text-body-md text-on-surface-variant mb-6">Theo dõi các thay đổi dữ liệu quan trọng trong hệ thống.</p>

      <div class="glass-panel rounded-2xl overflow-hidden">
        <div class="overflow-x-auto">
          <table>
            <thead>
              <tr>
                <th style="width: 15%">Thời gian</th>
                <th style="width: 15%">Bảng</th>
                <th style="width: 10%">Hành động</th>
                <th style="width: 15%">Record ID</th>
                <th style="width: 22%">Dữ liệu cũ</th>
                <th style="width: 23%">Dữ liệu mới</th>
              </tr>
            </thead>
            <tbody>
              <% if (logs.length > 0) { %>
                <% logs.forEach(function(log) { %>
                  <tr>
                    <td class="text-on-surface-variant text-label-sm">
                      <%= new Date(log.changed_at).toLocaleString('vi-VN') %>
                    </td>
                    <td class="font-medium"><%= log.table_name %></td>
                    <td>
                      <span class="badge <%= log.action === 'insert' ? 'badge-insert' : (log.action === 'update' ? 'badge-update' : 'badge-delete') %>">
                        <%= log.action %>
                      </span>
                    </td>
                    <td class="font-mono text-label-sm text-on-surface-variant"><%= log.record_id || 'N/A' %></td>
                    <td class="text-sm font-mono break-all text-on-surface-variant" style="max-width: 200px">
                      <%= log.old_data || '-' %>
                    </td>
                    <td class="text-sm font-mono break-all" style="max-width: 200px">
                      <%= log.new_data || '-' %>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr><td colspan="6" class="text-center text-on-surface-variant py-8">Chưa có bản ghi nhật ký nào.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</body>
</html>
