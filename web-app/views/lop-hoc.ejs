<%- include('partials/header', { title: 'Lớp học của tôi' }) %>
<%- include('partials/navbar') %>

<section class="max-w-[1280px] mx-auto px-4 md:px-10 pt-8 pb-16">
  <% if (error) { %>
    <div class="bg-error-container text-error px-4 py-3 rounded-lg text-body-md mb-4"><%= error %></div>
  <% } %>
  <% if (success) { %>
    <div class="bg-secondary-container text-on-secondary-container px-4 py-3 rounded-lg text-body-md mb-4"><%= success %></div>
  <% } %>

  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-headline-lg text-on-surface mb-2">Lớp học của tôi</h1>
      <p class="text-body-md text-on-surface-variant">
        <% if (role === 'gia_su') { %>
          Các lớp bạn đang dạy
        <% } else { %>
          Các lớp bạn đã tạo
        <% } %>
      </p>
    </div>
  </div>

  <% if (list && list.length > 0) { %>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      <% list.forEach(function(lop) { %>
        <a href="/lop-hoc/<%= lop.ma_lop %>" class="card no-underline text-on-surface block">
          <div class="flex items-start justify-between mb-3">
            <span class="badge <%= lop.trang_thai === 'dang_hoc' ? 'badge-active' : (lop.trang_thai === 'da_hoan_thanh' ? 'badge-open' : 'badge-pending') %>">
              <%= lop.trang_thai === 'dang_hoc' ? 'Đang học' : (lop.trang_thai === 'da_hoan_thanh' ? 'Hoàn thành' : lop.trang_thai) %>
            </span>
          </div>
          <h3 class="text-body-lg font-semibold mb-2">Lớp <%= lop.ma_lop %></h3>
          <div class="space-y-1 text-label-md text-on-surface-variant mb-3">
            <% if (role === 'gia_su') { %>
              <p>Học viên: <strong><%= lop.hoc_vien ? lop.hoc_vien.ho_ten : 'N/A' %></strong></p>
            <% } else { %>
              <p>Gia sư: <strong><%= lop.gia_su ? lop.gia_su.ho_ten : 'N/A' %></strong></p>
            <% } %>
            <p>Ngày bắt đầu: <strong><%= lop.ngay_bat_dau ? new Date(lop.ngay_bat_dau).toLocaleDateString('vi-VN') : 'Chưa có' %></strong></p>
            <p>Tổng số buổi: <strong><%= lop.tong_so_buoi || 'N/A' %></strong></p>
            <% if (lop.tong_tien) { %>
              <p>Tổng tiền: <strong><%= Number(lop.tong_tien).toLocaleString('vi-VN') %>₫</strong></p>
            <% } %>
          </div>
        </a>
      <% }); %>
    </div>
  <% } else { %>
    <div class="glass-panel rounded-2xl p-12 text-center">
      <p class="text-body-lg text-on-surface-variant mb-4">Bạn chưa có lớp học nào.</p>
      <% if (role === 'hoc_vien') { %>
        <a href="/dang-tin" class="btn-primary no-underline">Đăng yêu cầu tìm gia sư</a>
      <% } else { %>
        <a href="/yeu-cau" class="btn-primary no-underline">Xem yêu cầu đang mở</a>
      <% } %>
    </div>
  <% } %>
</section>

<%- include('partials/footer') %>
