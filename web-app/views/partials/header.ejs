            "primary-fixed": "#dae2ff",
            "on-surface-variant": "#424654",
            "on-surface": "#0b1c30",
            "secondary-fixed-dim": "#44ddc1",
            "on-background": "#0b1c30",
            "on-secondary-fixed": "#00201a",
            "on-tertiary": "#ffffff",
            "inverse-on-surface": "#eaf1ff",
            "surface-bright": "#f8f9ff",
            "surface": "#f8f9ff",
