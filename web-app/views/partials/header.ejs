            "on-surface": "#0b1c30",
            "secondary-fixed-dim": "#44ddc1",
            "on-background": "#0b1c30",
            "on-secondary-fixed": "#00201a",
            "on-tertiary": "#ffffff",
            "inverse-on-surface": "#eaf1ff",
            "surface-bright": "#f8f9ff",
            "surface": "#f8f9ff",
            "surface-dim": "#cbdbf5",
            "primary-container": "#0056d2",
            "tertiary-fixed": "#d3e5f1",
            "error": "#ba1a1a",
            "surface-container": "#e5eeff",
