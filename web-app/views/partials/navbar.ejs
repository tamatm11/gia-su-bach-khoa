<nav class="glass-nav fixed top-0 left-0 right-0 z-50 h-[72px] flex items-center">
  <div class="max-w-[1280px] mx-auto w-full px-4 md:px-10 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 no-underline">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 280 60" width="210" height="45">
        <rect width="280" height="60" fill="none"/>
        <path d="M22 18 L32 12 L42 18 L42 36 L32 42 L22 36 Z" fill="#1E40AF"/>
        <path d="M25 21 L32 16 L39 21 L39 33 L32 38 L25 33 Z" fill="#FFFFFF"/>
        <text x="55" y="38" font-family="Inter,sans-serif" font-weight="bold" font-size="18" fill="#1E40AF">Gia Sư Bách Khoa</text>
      </svg>
    </a>

    <!-- Nav Links -->
    <div class="hidden md:flex items-center gap-1">
      <a href="/" class="px-4 py-2 text-on-surface-variant hover:text-primary rounded-lg text-label-md transition-colors">Trang chủ</a>
      <a href="/yeu-cau" class="px-4 py-2 text-on-surface-variant hover:text-primary rounded-lg text-label-md transition-colors">Yêu cầu lớp</a>
      <% if (role === 'gia_su') { %>
        <a href="/lop-da-ung-tuyen" class="px-4 py-2 text-on-surface-variant hover:text-primary rounded-lg text-label-md transition-colors">Đã ứng tuyển</a>
        <a href="/lop-hoc" class="px-4 py-2 text-on-surface-variant hover:text-primary rounded-lg text-label-md transition-colors">Lớp của tôi</a>
        <a href="/lich-day" class="px-4 py-2 text-on-surface-variant hover:text-primary rounded-lg text-label-md transition-colors">Lịch dạy</a>
      <% } else if (role === 'hoc_vien') { %>
        <a href="/dang-tin" class="px-4 py-2 text-on-surface-variant hover:text-primary rounded-lg text-label-md transition-colors">Đăng tin</a>
        <a href="/yeu-cau-cua-toi" class="px-4 py-2 text-on-surface-variant hover:text-primary rounded-lg text-label-md transition-colors">Yêu cầu của tôi</a>
        <a href="/lop-hoc" class="px-4 py-2 text-on-surface-variant hover:text-primary rounded-lg text-label-md transition-colors">Lớp học</a>
      <% } %>
      <% if (isAdmin) { %>
        <a href="/admin" class="px-4 py-2 text-on-surface-variant hover:text-error rounded-lg text-label-md transition-colors font-semibold">Quản trị</a>
      <% } %>
    </div>

    <!-- User Menu -->
    <div class="flex items-center gap-3">
      <% if (user) { %>
        <!-- Notifications Bell -->
        <div class="relative notification-container">
          <button id="notifBell" class="relative p-2 text-on-surface-variant hover:text-primary rounded-full hover:bg-surface-container-low transition-all focus:outline-none flex items-center justify-center">
            <span class="material-symbols-outlined text-[24px]">notifications</span>
            <% if (unreadCount > 0) { %>
              <span class="absolute top-0 right-0 min-w-5 h-5 px-1 bg-error text-white text-[10px] font-bold rounded-full flex items-center justify-center animate-pulse" style="line-height: 1;">
                <%= unreadCount %>
              </span>
            <% } %>
          </button>
          
          <!-- Dropdown -->
          <div id="notifDropdown" class="hidden absolute right-0 mt-2 w-80 bg-surface-container-lowest border border-outline-variant rounded-2xl shadow-xl z-50 overflow-hidden">
            <div class="px-4 py-3 border-b border-outline-variant flex items-center justify-between bg-surface-container-low">
              <span class="text-label-md font-semibold text-on-surface">Thông báo</span>
              <% if (unreadCount > 0) { %>
                <button id="markAllRead" class="text-[11px] text-primary hover:underline font-semibold focus:outline-none bg-transparent border-0 cursor-pointer">Đọc tất cả</button>
              <% } %>
            </div>
            <div class="max-h-[300px] overflow-y-auto divide-y divide-outline-variant" id="notifList">
              <% if (notifications && notifications.length > 0) { %>
                <% notifications.forEach(function(n) { %>
                  <a href="/thong-bao/read/<%= n.ma_thong_bao %>" class="block px-4 py-3 hover:bg-surface-container-low no-underline text-left transition-colors <%= n.da_doc ? 'opacity-70' : 'bg-primary-container/10 font-semibold' %>">
                    <p class="text-body-sm text-on-surface leading-snug"><%= n.tieu_de %></p>
                    <p class="text-label-sm text-on-surface-variant mt-1"><%= n.noi_dung %></p>
                    <p class="text-[10px] text-on-surface-variant mt-1.5"><%= new Date(n.ngay_tao).toLocaleString('vi-VN') %></p>
                  </a>
                <% }); %>
              <% } else { %>
                <div class="px-4 py-6 text-center text-label-md text-on-surface-variant">Không có thông báo mới</div>
              <% } %>
            </div>
          </div>
        </div>

        <a href="/ho-so/chinh-sua" class="text-label-md text-on-surface-variant hidden md:inline flex items-center gap-1 hover:text-primary no-underline transition-colors">
          <span class="material-symbols-outlined text-[18px]">person</span>
          <%= user.ho_ten %>
        </a>
        <% if (role === 'gia_su') { %>
          <a href="/lich-day" class="badge <%= user.trong_lich ? 'badge-open' : 'badge-closed' %> text-decoration-none">
            <span class="status-dot <%= user.trong_lich ? 'status-dot-green' : 'status-dot-yellow' %>"></span>
            <%= user.trong_lich ? 'Đang trống lịch' : 'Đang bận' %>
          </a>
        <% } %>
        <form method="POST" action="/auth/logout" class="inline">
          <button type="submit" class="btn-outline" style="padding:6px 16px;font-size:13px;cursor:pointer;">Đăng xuất</button>
        </form>
      <% } else { %>
        <button onclick="openAuthModal('login')" class="btn-outline text-decoration-none" style="padding:7px 18px;font-size:14px;">Đăng nhập</button>
        <button onclick="openAuthModal('register')" class="btn-primary text-decoration-none" style="padding:8px 20px;font-size:14px;">Đăng ký</button>
      <% } %>
    </div>
  </div>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const bell = document.getElementById('notifBell');
    const dropdown = document.getElementById('notifDropdown');
    const markAllRead = document.getElementById('markAllRead');
    
    if (bell && dropdown) {
      bell.addEventListener('click', (e) => {
        e.stopPropagation();
        dropdown.classList.toggle('hidden');
      });
      
      document.addEventListener('click', (e) => {
        if (!dropdown.contains(e.target) && e.target !== bell) {
          dropdown.classList.add('hidden');
        }
      });
    }

    if (markAllRead) {
      markAllRead.addEventListener('click', async (e) => {
        e.preventDefault();
        e.stopPropagation();
        try {
          const res = await fetch('/thong-bao/read-all', { method: 'POST' });
          const data = await res.json();
          if (data.success) {
            window.location.reload();
          }
        } catch (err) {
          console.error(err);
        }
      });
    }
  });
</script>

