<%- include('partials/header', { title: 'Đặt lại mật khẩu' }) %>
<%- include('partials/navbar') %>

<div class="max-w-md mx-auto mt-20 px-4 md:px-0">
  <div class="glass-panel rounded-2xl p-8 shadow-lg">
    <h2 class="text-headline-md font-bold mb-2">Đặt lại mật khẩu</h2>
    <p class="text-on-surface-variant mb-6 text-body-md" id="statusMessage">Vui lòng nhập mật khẩu mới của bạn bên dưới.</p>
    
    <div id="alertContainer" class="hidden mb-4 p-3 rounded-lg text-body-md"></div>

    <form id="resetPasswordForm" class="space-y-4">
      <div>
        <label class="text-label-md text-on-surface-variant block mb-1">Mật khẩu mới</label>
        <input type="password" id="newPassword" required minlength="6" class="w-full px-3 py-2 border border-outline-variant rounded-lg bg-surface-container-lowest text-on-surface"/>
        <div class="mt-2 h-1 w-full bg-surface-variant rounded-full overflow-hidden">
          <div id="strengthBar" class="h-full bg-error w-0 transition-all duration-300"></div>
        </div>
        <p id="strengthText" class="text-label-sm text-on-surface-variant mt-1">Độ mạnh: Yếu (Ít nhất 6 ký tự)</p>
      </div>
      <div>
        <label class="text-label-md text-on-surface-variant block mb-1">Xác nhận mật khẩu mới</label>
        <input type="password" id="confirmPassword" required minlength="6" class="w-full px-3 py-2 border border-outline-variant rounded-lg bg-surface-container-lowest text-on-surface"/>
      </div>
      <button type="submit" id="submitBtn" class="btn-primary w-full py-2.5 mt-2 flex justify-center items-center gap-2">
        <span id="submitText">Cập nhật mật khẩu</span>
        <span class="material-symbols-outlined hidden animate-spin" id="submitSpinner">progress_activity</span>
      </button>
    </form>
    
    <div class="mt-4 text-center hidden" id="loginLinkContainer">
      <a href="/" class="text-primary hover:underline font-medium">Quay lại trang chủ để đăng nhập</a>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script>
  const supabaseUrl = '<%= supabaseUrl %>';
  const supabaseAnonKey = '<%= supabaseAnonKey %>';
  const supabase = window.supabase.createClient(supabaseUrl, supabaseAnonKey);

  const form = document.getElementById('resetPasswordForm');
  const alertContainer = document.getElementById('alertContainer');
  const submitBtn = document.getElementById('submitBtn');
  const loginLinkContainer = document.getElementById('loginLinkContainer');

  function showAlert(message, isError = true) {
    alertContainer.textContent = message;
    alertContainer.classList.remove('hidden', 'bg-error-container', 'text-error', 'bg-secondary-container', 'text-on-secondary-container');
    
    if (isError) {
      alertContainer.classList.add('bg-error-container', 'text-error');
    } else {
      alertContainer.classList.add('bg-secondary-container', 'text-on-secondary-container');
    }
  }

  // Check if we have an access token in the URL hash
  // Supabase automatically parses this and signs the user in
  supabase.auth.onAuthStateChange((event, session) => {
    if (event === 'PASSWORD_RECOVERY' || event === 'SIGNED_IN') {
      // User is ready to update their password
    }
  });

  const newPasswordInput = document.getElementById('newPassword');
  const strengthBar = document.getElementById('strengthBar');
  const strengthText = document.getElementById('strengthText');
  const submitText = document.getElementById('submitText');
  const submitSpinner = document.getElementById('submitSpinner');

  newPasswordInput.addEventListener('input', (e) => {
    const val = e.target.value;
    let strength = 0;
    if (val.length >= 6) strength += 25;
    if (val.length >= 8) strength += 25;
    if (/[A-Z]/.test(val)) strength += 25;
    if (/[0-9]/.test(val) || /[^A-Za-z0-9]/.test(val)) strength += 25;

    strengthBar.style.width = strength + '%';
    if (strength <= 25) {
      strengthBar.className = 'h-full bg-error transition-all duration-300';
      strengthText.textContent = 'Độ mạnh: Yếu';
    } else if (strength <= 50) {
      strengthBar.className = 'h-full bg-secondary transition-all duration-300';
      strengthText.textContent = 'Độ mạnh: Trung bình';
    } else {
      strengthBar.className = 'h-full bg-primary transition-all duration-300';
      strengthText.textContent = 'Độ mạnh: Mạnh';
    }
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const newPassword = newPasswordInput.value;
    const confirmPassword = document.getElementById('confirmPassword').value;

    if (newPassword !== confirmPassword) {
      showAlert('Mật khẩu xác nhận không khớp.');
      return;
    }

    if (newPassword.length < 6) {
      showAlert('Mật khẩu phải có ít nhất 6 ký tự.');
      return;
    }

    submitBtn.disabled = true;
    submitText.textContent = 'Đang xử lý...';
    submitSpinner.classList.remove('hidden');
    submitBtn.classList.add('opacity-70');

    try {
      const { data, error } = await supabase.auth.updateUser({ password: newPassword });
      
      if (error) {
        throw error;
      }
      
      showAlert('Cập nhật mật khẩu thành công! Bạn có thể đăng nhập bằng mật khẩu mới.', false);
      form.reset();
      form.style.display = 'none';
      document.getElementById('statusMessage').style.display = 'none';
      loginLinkContainer.classList.remove('hidden');
      
      // Đăng xuất khỏi supabase client để tránh lưu session ở client (vì ta dùng session ở server)
      await supabase.auth.signOut();
      
    } catch (error) {
      console.error(error);
      showAlert('Lỗi: ' + error.message);
      submitBtn.disabled = false;
      submitText.textContent = 'Cập nhật mật khẩu';
      submitSpinner.classList.add('hidden');
      submitBtn.classList.remove('opacity-70');
    }
  });
</script>

<%- include('partials/footer') %>
