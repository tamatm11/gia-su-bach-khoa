<%- include('partials/header', { title: 'Lịch dạy của tôi' }) %>
<%- include('partials/navbar') %>

<section class="max-w-[1280px] mx-auto px-4 md:px-10 pt-8 pb-16">
  <% if (error) { %>
    <div class="bg-error-container text-error px-4 py-3 rounded-lg text-body-md mb-4"><%= error %></div>
  <% } %>
  <% if (success) { %>
    <div class="bg-secondary-container text-on-secondary-container px-4 py-3 rounded-lg text-body-md mb-4"><%= success %></div>
  <% } %>

  <div class="flex flex-wrap items-start justify-between gap-4 mb-6">
    <div>
      <h1 class="text-headline-lg text-on-surface mb-2">Lịch dạy của tôi</h1>
      <p class="text-body-md text-on-surface-variant">Quản lý thời khóa biểu và trạng thái nhận lớp</p>
    </div>
    <form action="/toggle-trong-lich" method="POST">
      <button type="submit" class="<%= user && user.trong_lich ? 'btn-secondary' : 'btn-outline' %> flex items-center gap-2" style="padding:10px 20px;">
        <span class="status-dot <%= user && user.trong_lich ? 'status-dot-green' : 'status-dot-yellow' %>"></span>
        <%= user && user.trong_lich ? 'Đang trống lịch - Tắt' : 'Đang bận - Bật trống lịch' %>
      </button>
    </form>
  </div>

  <!-- Thời khóa biểu -->
  <div class="card overflow-x-auto">
    <h2 class="text-body-lg font-semibold mb-4">Thời khóa biểu tuần</h2>
    <% const thuNames = {1:'Chủ nhật',2:'Thứ 2',3:'Thứ 3',4:'Thứ 4',5:'Thứ 5',6:'Thứ 6',7:'Thứ 7'}; %>
    <% const thuOrder = [2,3,4,5,6,7,1]; %>
    <% if (lich && lich.length > 0) { %>
      <div class="min-w-[600px]">
        <% thuOrder.forEach(function(thu) {
          const lichTrongThu = lich.filter(function(l) { return l.thu_trong_tuan === thu; });
        %>
          <div class="flex border-b border-outline-variant last:border-b-0">
            <div class="w-20 py-3 px-3 text-label-md font-semibold text-on-surface-variant flex-shrink-0">
              <%= thuNames[thu] %>
            </div>
            <div class="flex-1 py-3 px-3">
              <% if (lichTrongThu.length > 0) { %>
                <div class="space-y-2">
                  <% lichTrongThu.forEach(function(l) { %>
                    <div class="flex items-center justify-between px-3 py-2 rounded-lg bg-primary-container/20">
                      <div class="flex items-center gap-3">
                        <span class="text-body-md font-medium"><%= l.gio_bat_dau ? l.gio_bat_dau.substring(0,5) : '' %> - <%= l.gio_ket_thuc ? l.gio_ket_thuc.substring(0,5) : '' %></span>
                      </div>
                      <div class="flex items-center gap-3">
                        <% if (l.ten_lop) { %>
                          <span class="text-label-sm text-on-surface-variant"><%= l.ten_lop || l.ma_lop %></span>
                        <% } %>
                        <% if (l.ho_ten_hoc_vien) { %>
                          <span class="text-label-sm text-primary">HV: <%= l.ho_ten_hoc_vien %></span>
                        <% } %>
                      </div>
                    </div>
                  <% }); %>
                </div>
              <% } else { %>
                <span class="text-label-sm text-on-surface-variant">- Trống -</span>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="text-center py-12">
        <p class="text-body-lg text-on-surface-variant mb-2">Bạn chưa có lịch dạy nào.</p>
        <p class="text-label-md text-on-surface-variant mb-4">Ứng tuyển vào các yêu cầu lớp để nhận lịch.</p>
        <a href="/yeu-cau" class="btn-primary no-underline">Xem yêu cầu đang mở</a>
      </div>
    <% } %>
  </div>

  <!-- Lịch sử dạy -->
  <div class="card mt-6">
    <h2 class="text-body-lg font-semibold mb-4">Lịch sử dạy</h2>
    <% if (lichSu && lichSu.length > 0) { %>
      <div class="overflow-x-auto">
        <table class="w-full text-label-md">
          <thead>
            <tr class="border-b border-outline-variant text-on-surface-variant">
              <th class="text-left py-2 px-3 font-semibold">Lớp</th>
              <th class="text-left py-2 px-3 font-semibold">Môn</th>
              <th class="text-left py-2 px-3 font-semibold">Học viên</th>
              <th class="text-left py-2 px-3 font-semibold">Ngày bắt đầu</th>
              <th class="text-left py-2 px-3 font-semibold">Ngày kết thúc</th>
              <th class="text-left py-2 px-3 font-semibold">Học phí/buổi</th>
              <th class="text-left py-2 px-3 font-semibold">Trạng thái</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-outline-variant">
            <% lichSu.forEach(function(lop) { %>
              <tr class="hover:bg-surface-container-low transition-colors">
                <td class="py-2 px-3"><a href="/lop-hoc/<%= lop.ma_lop %>" class="text-primary hover:underline"><%= lop.ma_lop %></a></td>
                <td class="py-2 px-3 text-on-surface-variant">
                  <%= lop.lop_hoc_mon && lop.lop_hoc_mon[0] ? lop.lop_hoc_mon[0].mon_hoc.ten_mon : '—' %>
                </td>
                <td class="py-2 px-3"><%= lop.hoc_vien ? lop.hoc_vien.ho_ten : '—' %></td>
                <td class="py-2 px-3 text-on-surface-variant"><%= lop.ngay_bat_dau ? new Date(lop.ngay_bat_dau).toLocaleDateString('vi-VN') : '—' %></td>
                <td class="py-2 px-3 text-on-surface-variant"><%= lop.ngay_ket_thuc ? new Date(lop.ngay_ket_thuc).toLocaleDateString('vi-VN') : '—' %></td>
                <td class="py-2 px-3"><%= Math.round(Number(lop.hoc_phi) / 1000) %>k</td>
                <td class="py-2 px-3">
                  <span class="badge <%= lop.trang_thai === 'da_hoan_thanh' ? 'badge-open' : 'badge-closed' %>">
                    <%= lop.trang_thai === 'da_hoan_thanh' ? 'Hoàn thành' : 'Đã hủy' %>
                  </span>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="text-label-md text-on-surface-variant text-center py-6">Chưa có lịch sử dạy.</p>
    <% } %>
  </div>

  <!-- Hướng dẫn -->
  <div class="card mt-6">
    <h3 class="text-body-lg font-semibold mb-3">Hướng dẫn</h3>
    <ul class="space-y-2 text-body-md text-on-surface-variant">
      <li class="flex items-start gap-2">
        <span class="material-symbols-outlined text-primary text-[20px]">check_circle</span>
        Bật <strong class="text-on-surface">Đang trống lịch</strong> để học viên biết bạn sẵn sàng nhận lớp mới.
      </li>
      <li class="flex items-start gap-2">
        <span class="material-symbols-outlined text-primary text-[20px]">schedule</span>
        Hệ thống tự động kiểm tra trùng lịch khi bạn ứng tuyển hoặc được thêm vào lớp mới.
      </li>
      <li class="flex items-start gap-2">
        <span class="material-symbols-outlined text-primary text-[20px]">info</span>
        Học viên sẽ chỉ thấy ứng tuyển từ gia sư đang trống lịch.
      </li>
    </ul>
  </div>
</section>

<%- include('partials/footer') %>
