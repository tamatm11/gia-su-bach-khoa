<%- include('partials/header', { title: 'Chi tiết lớp ' + (lop ? lop.ma_lop : '') }) %>
<%- include('partials/navbar') %>

<section class="max-w-[1280px] mx-auto px-4 md:px-10 pt-8 pb-16">
  <% if (error) { %>
    <div class="bg-error-container text-error px-4 py-3 rounded-lg text-body-md mb-4"><%= error %></div>
  <% } %>
  <% if (success) { %>
    <div class="bg-secondary-container text-on-secondary-container px-4 py-3 rounded-lg text-body-md mb-4"><%= success %></div>
  <% } %>

  <a href="/lop-hoc" class="inline-flex items-center gap-1 text-primary text-label-md mb-6 no-underline hover:underline">
    <span class="material-symbols-outlined text-[18px]">arrow_back</span> Quay lại danh sách lớp
  </a>

  <% if (lop) { %>
    <!-- Thông tin lớp -->
    <div class="card mb-6">
      <div class="flex flex-wrap items-start justify-between gap-2 mb-4">
        <div>
          <h1 class="text-headline-md text-on-surface mb-1">Chi tiết lớp <%= lop.ma_lop %></h1>
          <span class="badge <%= lop.trang_thai === 'dang_hoc' ? 'badge-active' : (lop.trang_thai === 'da_hoan_thanh' ? 'badge-open' : (lop.trang_thai === 'SapMo' ? 'badge-pending' : 'badge-closed')) %>">
            <%= lop.trang_thai === 'dang_hoc' ? 'Đang học' : (lop.trang_thai === 'da_hoan_thanh' ? 'Hoàn thành' : (lop.trang_thai === 'SapMo' ? 'Sắp mở' : (lop.trang_thai === 'da_huy' ? 'Đã hủy' : lop.trang_thai))) %>
          </span>
        </div>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4 text-label-md">
        <div>
          <span class="text-on-surface-variant">Gia sư:</span>
          <a href="/ho-so-gia-su/<%= lop.ma_gia_su %>" class="no-underline hover:text-primary">
            <strong class="block text-on-surface"><%= lop.gia_su ? lop.gia_su.ho_ten : 'N/A' %></strong>
          </a>
          <% if (lop.gia_su && lop.gia_su.trinh_do) { %>
            <span class="text-label-sm text-on-surface-variant"><%= lop.gia_su.trinh_do %></span>
          <% } %>
        </div>
        <div>
          <span class="text-on-surface-variant">Học viên:</span>
          <strong class="block"><%= lop.hoc_vien ? lop.hoc_vien.ho_ten : 'N/A' %></strong>
        </div>
        <div>
          <span class="text-on-surface-variant">Ngày bắt đầu:</span>
          <strong class="block"><%= lop.ngay_bat_dau ? new Date(lop.ngay_bat_dau).toLocaleDateString('vi-VN') : 'Chưa có' %></strong>
        </div>
        <div>
          <span class="text-on-surface-variant">Tổng số buổi:</span>
          <strong class="block"><%= lop.tong_so_buoi || 'N/A' %></strong>
        </div>
        <% if (lop.tong_tien) { %>
        <div>
          <span class="text-on-surface-variant">Tổng tiền:</span>
          <strong class="block"><%= Number(lop.tong_tien).toLocaleString('vi-VN') %>₫</strong>
        </div>
        <% } %>
      </div>
    </div>

    <div class="grid lg:grid-cols-2 gap-6">
      <!-- Lịch học -->
      <div class="card">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-body-lg font-semibold">Lịch học</h2>
          <% if (role === 'gia_su' || role === 'hoc_vien') { %>
            <button onclick="document.getElementById('them-lich-form').classList.toggle('hidden')" class="btn-secondary" style="padding:6px 16px;font-size:13px;">
              <span class="material-symbols-outlined text-[16px] align-middle">add</span> Thêm lịch
            </button>
          <% } %>
        </div>

        <!-- Form thêm lịch học -->
        <form id="them-lich-form" action="/lop-hoc/<%= lop.ma_lop %>/them-lich" method="POST" class="hidden mb-4 p-4 bg-surface-container-low rounded-lg space-y-3">
          <div class="grid grid-cols-3 gap-3">
            <div>
              <label class="text-label-sm text-on-surface-variant block mb-1">Thứ</label>
              <select name="thu_trong_tuan" required class="w-full px-2 py-2 border border-outline-variant rounded-lg bg-surface-container-lowest text-on-surface text-sm">
                <option value="2">Thứ 2</option>
                <option value="3">Thứ 3</option>
                <option value="4">Thứ 4</option>
                <option value="5">Thứ 5</option>
                <option value="6">Thứ 6</option>
                <option value="7">Thứ 7</option>
                <option value="1">Chủ nhật</option>
              </select>
            </div>
            <div>
              <label class="text-label-sm text-on-surface-variant block mb-1">Giờ bắt đầu</label>
              <input type="time" name="gio_bat_dau" required class="w-full px-2 py-2 border border-outline-variant rounded-lg bg-surface-container-lowest text-on-surface text-sm"/>
            </div>
            <div>
              <label class="text-label-sm text-on-surface-variant block mb-1">Giờ kết thúc</label>
              <input type="time" name="gio_ket_thuc" required class="w-full px-2 py-2 border border-outline-variant rounded-lg bg-surface-container-lowest text-on-surface text-sm"/>
            </div>
          </div>
          <button type="submit" class="btn-primary w-full" style="padding:8px;">Lưu lịch học</button>
        </form>

        <% const thuNames = {1:'CN',2:'T2',3:'T3',4:'T4',5:'T5',6:'T6',7:'T7'}; %>
        <% if (lichHoc && lichHoc.length > 0) { %>
          <div class="space-y-2">
            <% lichHoc.forEach(function(l) { %>
              <div class="flex items-center justify-between px-3 py-2 rounded-lg bg-surface-container-low">
                <div class="flex items-center gap-3">
                  <span class="badge badge-active"><%= thuNames[l.thu_trong_tuan] || l.thu_trong_tuan %></span>
                  <span class="text-body-md"><%= l.gio_bat_dau ? l.gio_bat_dau.substring(0,5) : '' %> - <%= l.gio_ket_thuc ? l.gio_ket_thuc.substring(0,5) : '' %></span>
                </div>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <p class="text-label-sm text-on-surface-variant">Chưa có lịch học nào.</p>
        <% } %>
      </div>

      <!-- Buổi học & Điểm danh -->
      <div class="card">
        <h2 class="text-body-lg font-semibold mb-4">Buổi học gần đây</h2>
        <% if (buoiHoc && buoiHoc.length > 0) { %>
          <div class="space-y-2 max-h-[400px] overflow-y-auto">
            <% buoiHoc.forEach(function(bh) { %>
              <div class="flex items-center justify-between px-3 py-2 rounded-lg bg-surface-container-low">
                <div>
                  <p class="text-body-md font-medium"><%= bh.ngay_hoc ? new Date(bh.ngay_hoc).toLocaleDateString('vi-VN') : 'N/A' %></p>
                  <% if (bh.gio_bat_dau) { %>
                    <p class="text-label-sm text-on-surface-variant"><%= bh.gio_bat_dau.substring(0,5) %> - <%= bh.gio_ket_thuc ? bh.gio_ket_thuc.substring(0,5) : '' %></p>
                  <% } %>
                </div>
                <span class="badge <%= bh.trang_thai === 'da_hoc' ? 'badge-active' : (bh.trang_thai === 'vang' ? 'badge-closed' : 'badge-pending') %>">
                  <%= bh.trang_thai === 'da_hoc' ? 'Đã học' : (bh.trang_thai === 'vang' ? 'Vắng' : bh.trang_thai || 'Chưa điểm danh') %>
                </span>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <p class="text-label-sm text-on-surface-variant">Chưa có buổi học nào.</p>
        <% } %>
      </div>
    </div>
  <% } else { %>
    <div class="glass-panel rounded-2xl p-12 text-center">
      <p class="text-body-lg text-on-surface-variant">Không tìm thấy lớp học.</p>
      <a href="/lop-hoc" class="btn-primary no-underline mt-4 inline-block">Quay lại danh sách lớp</a>
    </div>
  <% } %>
</section>

<%- include('partials/footer') %>
