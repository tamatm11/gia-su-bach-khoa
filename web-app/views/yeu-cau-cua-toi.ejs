<%- include('partials/header', { title: 'Yêu cầu của tôi' }) %>
<%- include('partials/navbar') %>

<section class="max-w-[1280px] mx-auto px-4 md:px-10 pt-8 pb-16">
  <% if (error) { %>
    <div class="bg-error-container text-error px-4 py-3 rounded-lg text-body-md mb-4"><%= error %></div>
  <% } %>
  <% if (success) { %>
    <div class="bg-secondary-container text-on-secondary-container px-4 py-3 rounded-lg text-body-md mb-4"><%= success %></div>
  <% } %>

  <h1 class="text-headline-lg text-on-surface mb-2">Yêu cầu của tôi</h1>
  <p class="text-body-md text-on-surface-variant mb-8">Quản lý yêu cầu tìm gia sư và xem ứng tuyển</p>

  <% if (list && list.length > 0) { %>
    <% list.forEach(function(yc) { %>
      <div class="card mb-6">
        <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
          <div class="flex items-center gap-2">
            <h3 class="text-body-lg font-semibold"><%= yc.tieu_de %></h3>
            <% if (yc.trang_thai === 'open') { %>
              <span class="badge badge-open">Đang mở</span>
            <% } else if (yc.trang_thai === 'closed') { %>
              <span class="badge badge-closed">Đã chọn gia sư</span>
            <% } else if (yc.trang_thai === 'approved') { %>
              <span class="badge badge-active">Đã tạo lớp</span>
            <% } else { %>
              <span class="badge badge-pending"><%= yc.trang_thai %></span>
            <% } %>
          </div>
          <span class="text-label-sm text-on-surface-variant"><%= new Date(yc.ngay_yeu_cau).toLocaleDateString('vi-VN') %></span>
        </div>

        <div class="grid md:grid-cols-4 gap-2 text-label-md text-on-surface-variant mb-1">
          <div>Học phí: <strong><%= Math.round(Number(yc.tien_hoc_phi) / 1000) %>k/buổi</strong></div>
          <div>Hình thức: <strong><%= yc.hinh_thuc_hoc %></strong></div>
          <div>Số buổi: <strong><%= yc.so_buoi_tuan %>/tuần</strong></div>
          <div>Địa chỉ: <strong><%= yc.dia_chi || 'Chưa có' %></strong></div>
        </div>

        <% if (yc.ma_gia_su_duoc_chon) { %>
          <p class="text-label-md text-secondary mt-2">
            <span class="material-symbols-outlined text-[16px] align-middle">check_circle</span>
            Đã chọn gia sư — ngày chọn: <%= yc.ngay_chon_gia_su ? new Date(yc.ngay_chon_gia_su).toLocaleDateString('vi-VN') : 'N/A' %>
          </p>
        <% } %>

        <!-- Danh sách ứng tuyển -->
        <% var ungTuyenForYc = utList.filter(function(ut) { return ut.ma_yeu_cau === yc.ma_yeu_cau; }); %>
        <% if (ungTuyenForYc.length > 0) { %>
          <div class="mt-4 pt-4 border-t border-outline-variant">
            <h4 class="text-label-md font-semibold mb-3">Gia sư đã ứng tuyển (<%= ungTuyenForYc.length %>)</h4>
            <div class="space-y-3">
              <% ungTuyenForYc.forEach(function(ut) { %>
                <div class="flex items-start justify-between p-3 rounded-lg bg-surface-container-low">
                  <div class="flex-1">
                    <div class="flex items-center gap-2">
                      <a href="/ho-so-gia-su/<%= ut.ma_gia_su %>?ma_yeu_cau=<%= yc.ma_yeu_cau %>" class="font-semibold text-body-md text-on-surface no-underline hover:text-primary"><%= ut.gia_su ? ut.gia_su.ho_ten : 'N/A' %></a>
                      <span class="badge <%= ut.trang_thai === 'accepted' ? 'badge-active' : (ut.trang_thai === 'rejected' ? 'badge-closed' : 'badge-pending') %>"><%= ut.trang_thai %></span>
                    </div>
                    <p class="text-label-sm text-on-surface-variant mt-1"><%= ut.loi_nhan || 'Không có lời nhắn' %></p>
                    <% if (ut.thu_nhap_mong_muon) { %>
                      <p class="text-label-sm text-primary mt-1">Mong muốn: <%= Math.round(Number(ut.thu_nhap_mong_muon) / 1000) %>k/buổi</p>
                    <% } %>
                  </div>
                  <% if (ut.trang_thai === 'pending' && yc.trang_thai === 'open') { %>
                    <button type="button" onclick="openDuyetModal('<%= yc.ma_yeu_cau %>', '<%= ut.ma_gia_su %>', '<%= ut.gia_su ? ut.gia_su.ho_ten.replace(/'/g, `\\'`) : '' %>')" class="btn-secondary ml-3" style="padding:6px 16px;font-size:13px;">Chọn gia sư này</button>
                  <% } %>
                </div>
              <% }); %>
            </div>
          </div>
        <% } else if (yc.trang_thai === 'open') { %>
          <p class="text-label-sm text-on-surface-variant mt-3">Chưa có gia sư nào ứng tuyển.</p>
        <% } %>


      </div>
    <% }); %>
  <% } else { %>
    <div class="glass-panel rounded-2xl p-12 text-center">
      <p class="text-body-lg text-on-surface-variant mb-4">Bạn chưa có yêu cầu nào.</p>
      <a href="/dang-tin" class="btn-primary no-underline">Đăng yêu cầu đầu tiên</a>
    </div>
  <% } %>
</section>

<!-- Modal Duyệt Gia Sư -->
<div id="duyetModal" class="hidden fixed inset-0 z-[100] flex items-center justify-center bg-black/40 backdrop-blur-sm">
  <div class="glass-panel rounded-2xl p-6 w-full max-w-md mx-4">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-headline-md">Xác nhận duyệt gia sư</h3>
      <button onclick="closeDuyetModal()" class="text-on-surface-variant hover:text-on-surface">
        <span class="material-symbols-outlined">close</span>
      </button>
    </div>
    <form action="/chon-gia-su" method="POST">
      <input type="hidden" name="ma_yeu_cau" id="duyetMaYeuCau"/>
      <input type="hidden" name="ma_gia_su" id="duyetMaGiaSu"/>
      <div class="space-y-4">
        <p class="text-body-md text-on-surface-variant mb-2">Bạn đang duyệt gia sư <strong id="duyetTenGiaSu" class="text-primary"></strong>. Vui lòng chọn thời gian để hệ thống tự tạo lớp:</p>
        
        <div>
          <label class="text-label-sm text-on-surface-variant block mb-1">Ngày bắt đầu dự kiến</label>
          <input type="date" name="ngay_bat_dau" id="duyetNgayBatDau" required class="w-full px-3 py-2 border border-outline-variant rounded-lg bg-surface-container-lowest text-on-surface"/>
        </div>
        <div>
          <label class="text-label-sm text-on-surface-variant block mb-1">Tổng số buổi</label>
          <input type="number" name="tong_so_buoi" value="24" required min="1" class="w-full px-3 py-2 border border-outline-variant rounded-lg bg-surface-container-lowest text-on-surface"/>
        </div>
        
        <button type="submit" class="btn-primary w-full mt-2">Duyệt & Tạo lớp học</button>
      </div>
    </form>
  </div>
</div>
<script>
  function openDuyetModal(maYc, maGs, tenGs) {
    document.getElementById('duyetMaYeuCau').value = maYc;
    document.getElementById('duyetMaGiaSu').value = maGs;
    document.getElementById('duyetTenGiaSu').textContent = tenGs;
    
    // Set default date to tomorrow
    const tomorrow = new Date();
    tomorrow.setDate(tomorrow.getDate() + 1);
    document.getElementById('duyetNgayBatDau').value = tomorrow.toISOString().split('T')[0];
    
    document.getElementById('duyetModal').classList.remove('hidden');
  }
  function closeDuyetModal() {
    document.getElementById('duyetModal').classList.add('hidden');
  }
</script>

<%- include('partials/footer') %>
